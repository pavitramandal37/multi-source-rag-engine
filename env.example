DJANGO_SECRET_KEY=replace-me-with-a-secure-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=rag_support
DB_USER=rag_user
DB_PASSWORD=rag_password
DB_HOST=db
DB_PORT=5432

LLM_API_KEY=ollama
LLM_API_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL_NAME=llama3.2
# Embedding model — output dim must match VECTOR_DIMENSIONS below.
# nomic-embed-text → 768 | BAAI/bge-small-en → 384 | text-embedding-3-small → 1536
# Pull with: ollama pull nomic-embed-text
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_NAME=nomic-embed-text
VECTOR_DIMENSIONS=1536

# RAG pipeline toggles (set to false to speed up during demos)
RAG_USE_HYDE=true
RAG_USE_CRAG=true
RAG_CRAG_THRESHOLD=0.6
URL_CRAWL_DEFAULT_DEPTH=2

